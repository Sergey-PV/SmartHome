APP_ENV=production
APP_NAME=SmartHome Auth Middleware
HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO
LOG_HTTP_HEADERS=true
LOG_HTTP_BODIES=true
LOG_HTTP_BODY_MAX_LENGTH=32768

DATABASE_URL=postgresql+asyncpg://smarthome_auth:change_me@127.0.0.1:5432/smarthome_auth
TOKEN_HASH_SECRET=change-me-long-random-secret

ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
BIOMETRIC_TOKEN_TTL_SECONDS=15552000
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_TTL_SECONDS=300

CORS_ALLOW_ORIGINS=https://your-ios-api-gateway.example.com,https://your-admin.example.com
CORS_ALLOW_CREDENTIALS=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_BIOMETRIC_PER_MINUTE=15

METRICS_ENABLED=true

SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=StrongPassword123!
SEED_USER_FIRST_NAME=Sergey
SEED_USER_LAST_NAME=Ivanov
SEED_USER_EMAIL_VERIFIED=true
